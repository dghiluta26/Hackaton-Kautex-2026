# Copy this file to secrets.toml (same folder) and fill in your real
# Supabase connection string. secrets.toml is gitignored — never commit it.
#
# Get this from: Supabase project -> Settings -> Database -> Connection string
# Use the "Session pooler" URI (port 6543) for Streamlit Cloud / serverless.
DATABASE_URL = "postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres"
